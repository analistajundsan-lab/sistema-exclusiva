# Sistema Exclusiva - variaveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# Nunca faca commit do .env real.

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sistema_exclusiva

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET_KEY=SUBSTITUA_POR_CHAVE_SECRETA_FORTE_DE_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","https://sistema-exclusiva-pied.vercel.app"]
ALLOWED_ORIGIN_REGEX=https://sistema-exclusiva.*\.vercel\.app

POSTGRES_DB=sistema_exclusiva
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

LOG_LEVEL=INFO
VITE_API_URL=http://localhost:8000

# Copie para .env em desenvolvimento local e preencha os valores.
# Em producao no Fly.io, configure estes valores como secrets.

DATABASE_URL=postgresql://usuario:senha@host:5432/sistema_exclusiva

# Gere com: openssl rand -hex 32
JWT_SECRET_KEY=troque-por-uma-chave-aleatoria-forte-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

ENVIRONMENT=production
LOG_LEVEL=INFO

# Redis e opcional no MVP.
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend oficial fica no Vercel.
ALLOWED_ORIGINS=https://sistema-exclusiva-pied.vercel.app,https://sistema-exclusiva.fly.dev
ALLOWED_ORIGIN_REGEX=https://sistema-exclusiva.*\.vercel\.app

# Mantenha false quando a API estiver publica.
EXPOSE_METRICS=false

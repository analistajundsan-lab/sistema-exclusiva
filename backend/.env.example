# Copie para .env e preencha os valores

# Supabase PostgreSQL — pegue em: Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Chave secreta JWT — gere com: openssl rand -hex 32
JWT_SECRET_KEY=troque-por-uma-chave-aleatoria-forte-32-chars

# Ambiente
ENVIRONMENT=production

# Redis (opcional para MVP — sistema funciona sem ele)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS — separe com vírgulas se quiser adicionar mais origens
ALLOWED_ORIGINS=https://sistema-exclusiva-pied.vercel.app

# Métricas Prometheus (false em produção pública)
EXPOSE_METRICS=false
